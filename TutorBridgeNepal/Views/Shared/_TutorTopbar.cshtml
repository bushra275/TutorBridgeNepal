@{
    var initials = ViewData["SidebarInitials"] as string ?? "?";
    var name = ViewData["SidebarName"] as string ?? "";
    var isAvailable = ViewData["IsAvailableNow"] as bool? ?? false;
    var pendingCount = ViewData["PendingRequestCount"] as int? ?? 0;
    var unreadCount = ViewData["UnreadMessageCount"] as int? ?? 0;
    var alertCount = pendingCount + unreadCount;
}
<header class="dash-topbar">
    <a class="tb-brand" asp-controller="Home" asp-action="Index">TutorBridge <span>Nepal</span></a>

    <div class="dash-search">
        <input type="text" placeholder="Search students, sessions..." disabled title="Search isn't built yet" />
    </div>

    <form asp-controller="Tutor" asp-action="ToggleAvailability" method="post" style="margin:0;">
        @Html.AntiForgeryToken()
        <button type="submit" class="badge-soft availability-pill" style="border:none; cursor:pointer;" title="Click to toggle">
            <span class="avail-dot" style="background:@(isAvailable ? "var(--green-2)" : "var(--muted)");"></span>
            @(isAvailable ? "Available now" : "Not available")
        </button>
    </form>

    <div class="dash-topbar-right">
        <a asp-controller="Tutor" asp-action="Dashboard" asp-fragment="pending-requests" class="icon-btn" title="Pending requests + unread messages" style="position:relative;">
            🔔
            @if (alertCount > 0)
            {
                <span class="topbar-badge">@(alertCount > 9 ? "9+" : alertCount.ToString())</span>
            }
        </a>
        <div class="topbar-avatar" title="@name">@initials</div>
    </div>
</header>