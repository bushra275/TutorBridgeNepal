@{
    var name = ViewData["SidebarName"] as string ?? "";
    var initials = ViewData["SidebarInitials"] as string ?? "?";
    var meta = ViewData["SidebarMeta"] as string ?? "Tutor";
    var activeNav = ViewData["ActiveNav"] as string ?? "";
    var pendingCount = ViewData["PendingRequestCount"] as int? ?? 0;
    var unreadCount = ViewData["UnreadMessageCount"] as int? ?? 0;
}
<aside class="dash-sidebar">
    <div class="dash-user">
        <div class="avatar">@initials</div>
        <div>
            <div class="name">@name</div>
            <div class="meta">@meta</div>
            <span class="role-chip">Tutor</span>
        </div>
    </div>

    <ul class="dash-nav">
        <li><a asp-controller="Tutor" asp-action="Dashboard" class="@(activeNav == "dashboard" ? "active" : "")"><span class="nav-icon">🏠</span> Dashboard</a></li>
        <li><span class="disabled-nav-link" title="Coming soon"><span class="nav-icon">🗓️</span> My Schedule</span></li>
        <li>
            <a asp-controller="Tutor" asp-action="Dashboard" asp-fragment="pending-requests" class="@(activeNav == "dashboard" ? "active" : "")">
                <span class="nav-icon">📥</span> Session Requests
                @if (pendingCount > 0)
                {
                    <span class="badge-count">@pendingCount</span>
                }
            </a>
        </li>
        <li><span class="disabled-nav-link" title="Coming soon"><span class="nav-icon">👥</span> My Students</span></li>
        <li>
            <span class="disabled-nav-link" title="Tutor-side messaging isn't built yet">
                <span class="nav-icon">💬</span> Messages
                @if (unreadCount > 0)
                {
                    <span class="badge-count">@unreadCount</span>
                }
            </span>
        </li>
        <li><span class="disabled-nav-link" title="Coming soon"><span class="nav-icon">⭐</span> Reviews</span></li>
        <li><span class="disabled-nav-link" title="Coming soon"><span class="nav-icon">👤</span> My Profile</span></li>
    </ul>

    <ul class="dash-nav-secondary">
        <li><span class="disabled-nav-link" title="Coming soon"><span class="nav-icon">⚙️</span> Settings</span></li>
        <li><span class="disabled-nav-link" title="Coming soon"><span class="nav-icon">❓</span> Help &amp; Support</span></li>
        <li><a asp-controller="Account" asp-action="Logout"><span class="nav-icon">↩️</span> Log out</a></li>
    </ul>
</aside>