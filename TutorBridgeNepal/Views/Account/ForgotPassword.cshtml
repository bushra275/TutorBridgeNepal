@model TutorBridgeNepal.ViewModels.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Forgot Password";
    var isTutor = Model.Role == "Tutor";
}

<main class="auth-page">
    <aside class="auth-side @(isTutor ? "tutor" : "")">
        <div class="auth-side-content">
            <h2 class="auth-logo @(isTutor ? "" : "serif")">TutorBridge Nepal</h2>
            <p class="auth-small">Connecting learners with verified tutors</p>
            <h1 class="auth-side-title @(isTutor ? "" : "serif")">Forgot your<br /><span>password?</span><br />No problem.</h1>
            <p class="auth-side-copy">Enter your email and we'll help you get back into your account.</p>
        </div>
        <div class="auth-sdg">SDG 4: Quality Education</div>
    </aside>

    <section class="auth-main">
        <div class="auth-top">
            <a class="back-link" asp-action="@(isTutor ? "TutorLogin" : "StudentLogin")">← Back to login</a>
        </div>

        <div class="auth-panel">
            <div class="auth-heading">
                <h1 class="@(isTutor ? "" : "serif")">Reset your password</h1>
                <p>Enter the email address on your @(isTutor ? "tutor" : "student") account.</p>
            </div>

            <form asp-action="ForgotPassword" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Role" />
                <div asp-validation-summary="ModelOnly"></div>

                <div class="field mb-3">
                    <label asp-for="Email">Email Address</label>
                    <input asp-for="Email" class="tb-input" placeholder="Enter your email" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <button class="tb-btn @(isTutor ? "dark" : "") w-100" type="submit">Send reset link</button>
            </form>

            <p class="auth-bottom">Remembered your password? <a class="link-green" asp-action="@(isTutor ? "TutorLogin" : "StudentLogin")">Log in</a></p>
        </div>
    </section>
</main>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}