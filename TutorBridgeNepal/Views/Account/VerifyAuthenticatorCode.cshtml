@model TutorBridgeNepal.ViewModels.TwoFactorViewModel
@{
    ViewData["Title"] = "Admin Verification";
}

<main class="auth-page">
    <aside class="auth-side admin">
        <div class="auth-side-content">
            <h2 class="auth-logo">TutorBridge Nepal</h2>
            <p class="auth-small">🛠 Admin Portal</p>

            <h1 class="auth-side-title">One more step<br /><span>to confirm</span><br />it's really you.</h1>
            <p class="auth-side-copy">Two-factor authentication protects the admin portal from unauthorized access.</p>

            <div class="quote-card">
                <strong>🔒 Restricted access</strong>
                <p class="mb-0 mt-2">This portal is only for authorized platform administrators.</p>
            </div>
        </div>
        <div class="auth-sdg">SDG 4: Quality Education</div>
    </aside>

    <section class="auth-main">
        <div class="auth-top">
            <a class="back-link" asp-controller="Account" asp-action="AdminLogin">← Back to admin login</a>
        </div>

        <div class="auth-panel admin-panel">
            <div class="auth-heading">
                <div class="admin-chip">🛠 Admin access</div>
                <h1 class="mt-2">Enter authenticator code</h1>
                <p>Open your authenticator app and enter the 6-digit code for TutorBridge Nepal.</p>
            </div>

            <form asp-action="VerifyAuthenticatorCode" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="RememberMe" />
                <div asp-validation-summary="ModelOnly"></div>

                <div class="field mb-3">
                    <label asp-for="Code">6-digit code</label>
                    <input asp-for="Code" class="tb-input" placeholder="000000" autocomplete="one-time-code" maxlength="7" />
                    <span asp-validation-for="Code" class="text-danger small"></span>
                </div>

                <button class="tb-btn brown w-100" type="submit">Verify &amp; Sign In</button>
                <div class="admin-warning">⚠ Unauthorized access is logged and reported<br />All admin actions are recorded for security audits.</div>
            </form>
        </div>
    </section>
</main>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}