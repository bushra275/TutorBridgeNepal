@model TutorBridgeNepal.ViewModels.ResetPasswordViewModel
@{
    ViewData["Title"] = "Reset Password";
    var isAdmin = Model.Role == "Admin";
    var isTutor = Model.Role == "Tutor";
    var loginAction = isAdmin ? "AdminLogin" : isTutor ? "TutorLogin" : "StudentLogin";
    var btnClass = isAdmin ? "brown" : isTutor ? "dark" : "";
    var asideClass = isAdmin ? "admin" : isTutor ? "tutor" : "";
}

<main class="auth-page">
    <aside class="auth-side @asideClass">
        <div class="auth-side-content">
            <h2 class="auth-logo @(isAdmin || isTutor ? "" : "serif")">TutorBridge Nepal</h2>
            <p class="auth-small">@(isAdmin ? "🛠 Admin Portal" : "Connecting learners with verified tutors")</p>
            <h1 class="auth-side-title @(isAdmin || isTutor ? "" : "serif")">Choose a new<br /><span>password.</span></h1>
            <p class="auth-side-copy">Make it something strong you haven't used before.</p>
        </div>
        <div class="auth-sdg">SDG 4: Quality Education</div>
    </aside>

    <section class="auth-main">
        <div class="auth-top">
            <a class="back-link" asp-action="@loginAction">← Back to login</a>
        </div>

        <div class="auth-panel">
            <div class="auth-heading">
                @if (isAdmin)
                {
                    <div class="admin-chip">🛠 Admin access</div>
                }
                <h1 class="mt-2 @(isAdmin || isTutor ? "" : "serif")">Set a new password</h1>
                <p>For @Model.Email</p>
            </div>

            <form asp-action="ResetPassword" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Email" />
                <input type="hidden" asp-for="Token" />
                <input type="hidden" asp-for="Role" />
                <div asp-validation-summary="ModelOnly"></div>

                <div class="field mb-3">
                    <label asp-for="Password">New Password</label>
                    <div class="password-wrap">
                        <input asp-for="Password" type="password" class="tb-input" placeholder="Create a new password" />
                        <span class="eye-dot"></span>
                    </div>
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="field">
                    <label asp-for="ConfirmPassword">Confirm New Password</label>
                    <input asp-for="ConfirmPassword" type="password" class="tb-input" placeholder="Re-enter new password" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>

                <button class="tb-btn @btnClass w-100 mt-3" type="submit">Reset password</button>
            </form>
        </div>
    </section>
</main>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}