@model TutorBridgeNepal.ViewModels.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Check Your Email";
    var isTutor = Model.Role == "Tutor";
    var resetLink = ViewData["ResetLink"] as string;
}

<main class="auth-page">
    <aside class="auth-side @(isTutor ? "tutor" : "")">
        <div class="auth-side-content">
            <h2 class="auth-logo @(isTutor ? "" : "serif")">TutorBridge Nepal</h2>
            <p class="auth-small">Connecting learners with verified tutors</p>
            <h1 class="auth-side-title @(isTutor ? "" : "serif")">Almost there.</h1>
            <p class="auth-side-copy">Follow the reset instructions to get back into your account.</p>
        </div>
        <div class="auth-sdg">SDG 4: Quality Education</div>
    </aside>

    <section class="auth-main">
        <div class="auth-top">
            <a class="back-link" asp-action="@(isTutor ? "TutorLogin" : "StudentLogin")">← Back to login</a>
        </div>

        <div class="auth-panel">
            <div class="auth-heading">
                <h1 class="@(isTutor ? "" : "serif")">Check your email</h1>
                <p>If an account exists for <strong>@Model.Email</strong>, password reset instructions have been sent.</p>
            </div>

            @if (!string.IsNullOrEmpty(resetLink))
            {
                <div class="quote-card">
                    <strong>📧 Email sending isn't configured yet</strong>
                    <p class="mb-2 mt-2">For now, here's your reset link directly (this box will be replaced by a real email once SMTP is set up):</p>
                    <p class="mb-0"><a class="link-green" href="@resetLink" style="word-break:break-all;">@resetLink</a></p>
                </div>
            }

            <p class="auth-bottom">Didn't get anywhere? <a class="link-green" asp-action="ForgotPassword" asp-route-role="@Model.Role">Try again</a></p>
        </div>
    </section>
</main>