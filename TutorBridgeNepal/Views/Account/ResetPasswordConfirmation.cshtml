@{
    ViewData["Title"] = "Password Reset Complete";
    var role = ViewData["Role"] as string ?? "Student";
    var isTutor = role == "Tutor";
}

<main class="auth-page">
    <aside class="auth-side @(isTutor ? "tutor" : "")">
        <div class="auth-side-content">
            <h2 class="auth-logo @(isTutor ? "" : "serif")">TutorBridge Nepal</h2>
            <p class="auth-small">Connecting learners with verified tutors</p>
            <h1 class="auth-side-title @(isTutor ? "" : "serif")">You're all<br /><span>set.</span></h1>
        </div>
        <div class="auth-sdg">SDG 4: Quality Education</div>
    </aside>

    <section class="auth-main">
        <div class="auth-panel text-center">
            <div class="auth-heading">
                <h1 class="@(isTutor ? "" : "serif")">Password reset successful</h1>
                <p>You can now log in with your new password.</p>
            </div>

            <a class="tb-btn @(isTutor ? "dark" : "") w-100" asp-action="@(isTutor ? "TutorLogin" : "StudentLogin")">Go to login</a>
        </div>
    </section>
</main>