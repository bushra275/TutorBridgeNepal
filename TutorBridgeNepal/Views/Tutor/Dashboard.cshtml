@model TutorBridgeNepal.ViewModels.TutorDashboardViewModel
@{
    ViewData["Title"] = "Tutor Dashboard";
    Layout = null;

    var now = DateTime.Now;
    var greeting = now.Hour < 12 ? "Good morning" : now.Hour < 17 ? "Good afternoon" : "Good evening";
    var firstName = Model.FullName.Split(' ', StringSplitOptions.RemoveEmptyEntries).FirstOrDefault() ?? Model.FullName;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Tutor Dashboard - TutorBridge Nepal</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Playfair+Display:wght@700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/tutor-dashboard.css" asp-append-version="true" />
</head>
<body>
    <div class="dash-shell">
        @await Html.PartialAsync("_TutorTopbar")

        <div class="dash-body">
            @await Html.PartialAsync("_TutorSidebar")

            <main class="dash-main">
                <div class="dash-greeting">
                    <h1>@greeting, @firstName 👋</h1>
                    <p>@now.ToString("dddd, d MMMM yyyy") · You have @Model.TodaySessionsCount session@(Model.TodaySessionsCount == 1 ? "" : "s") today</p>
                </div>

                <div class="stat-cards">
                    <div class="stat-card">
                        <div class="label">Total sessions</div>
                        <div class="value">@Model.TotalSessions</div>
                        <div class="delta">+@Model.TotalSessionsThisMonth this month</div>
                    </div>
                    <div class="stat-card">
                        <div class="label">Active students</div>
                        <div class="value">@Model.ActiveStudentsCount</div>
                        <div class="delta">+@Model.NewStudentsThisMonth this month</div>
                    </div>
                    <div class="stat-card">
                        <div class="label">Hours taught</div>
                        <div class="value">@Model.HoursTaught.ToString("0.#")h</div>
                        <div class="sub">Lifetime total</div>
                    </div>
                    <div class="stat-card">
                        @if (Model.ReviewCount > 0)
                        {
                            <div class="label">Avg rating</div>
                            <div class="rating-value"><span class="value">@Model.AverageRating.ToString("0.0")</span><span class="star">★</span></div>
                            <div class="sub">@Model.ReviewCount review@(Model.ReviewCount == 1 ? "" : "s")</div>
                        }
                        else
                        {
                            <div class="label">Avg rating</div>
                            <div class="value">—</div>
                            <div class="sub">No reviews yet</div>
                        }
                    </div>
                </div>

                <div class="dash-columns">
                    <div>
                        <div class="panel">
                            <div class="panel-head">
                                <h2>Today's schedule</h2>
                                <span class="tag-count">@Model.TodaySessionsCount today</span>
                            </div>

                            @if (!Model.TodaySchedule.Any())
                            {
                                <p class="empty-state">No confirmed sessions today.</p>
                            }
                            else
                            {
                                @foreach (var s in Model.TodaySchedule)
                                {
                                    var started = s.StartTime <= now;
                                    <div class="session-card">
                                        <div class="avatar">@s.StudentInitials</div>
                                        <div class="session-info">
                                            <div class="name">@s.StudentName</div>
                                            <div class="meta">@s.Subject@(string.IsNullOrWhiteSpace(s.StudentGradeLevel) ? "" : " · " + s.StudentGradeLevel)</div>
                                            <div class="time">Today, @s.StartTime.ToString("h:mm tt") – @s.EndTime.ToString("h:mm tt")</div>
                                        </div>
                                        <div class="session-actions">
                                            <span class="pill pill-confirmed">Confirmed</span>
                                            <div class="session-btn-row">
                                                @if (started)
                                                {
                                                    <form asp-controller="Tutor" asp-action="MarkSessionCompleted" method="post" style="margin:0;">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="id" value="@s.BookingId" />
                                                        <button type="submit" class="mini-btn green">Mark completed</button>
                                                    </form>
                                                }
                                                else
                                                {
                                                    <span class="disabled-btn" title="Session hasn't started yet">Not started</span>
                                                }
                                                <span class="disabled-btn" title="Tutor-side messaging isn't built yet">Message student</span>
                                            </div>
                                        </div>
                                    </div>
                                }
                            }
                        </div>

                        <div class="panel" id="pending-requests">
                            <div class="panel-head">
                                <h2>Pending session requests</h2>
                                @if (Model.PendingRequestsCount > 0)
                                {
                                    <span class="tag-count" style="background:#fff1d5;color:#a96808;">@Model.PendingRequestsCount</span>
                                }
                            </div>

                            @if (!Model.PendingRequests.Any())
                            {
                                <p class="empty-state">No pending requests right now.</p>
                            }
                            else
                            {
                                @foreach (var r in Model.PendingRequests)
                                {
                                    var minutesAgo = (int)(now - r.RequestedAt).TotalMinutes;
                                    var agoText = minutesAgo < 1 ? "just now"
                                        : minutesAgo < 60 ? $"{minutesAgo} minute{(minutesAgo == 1 ? "" : "s")} ago"
                                        : minutesAgo < 1440 ? $"{minutesAgo / 60} hour{(minutesAgo / 60 == 1 ? "" : "s")} ago"
                                        : $"{minutesAgo / 1440} day{(minutesAgo / 1440 == 1 ? "" : "s")} ago";
                                    <div class="request-card">
                                        <div class="avatar">@r.StudentInitials</div>
                                        <div class="request-info">
                                            <div class="name">@r.StudentName</div>
                                            <div class="meta">@r.Subject · Requested for @r.StartTime.ToString("d MMM, h:mm tt")</div>
                                            <div class="ago">Requested @agoText</div>
                                        </div>
                                        <div class="request-actions">
                                            <form asp-controller="Tutor" asp-action="AcceptBooking" method="post" style="margin:0;">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@r.BookingId" />
                                                <button type="submit" class="mini-btn green" style="width:100%;">Accept</button>
                                            </form>
                                            <form asp-controller="Tutor" asp-action="DeclineBooking" method="post" style="margin:0;" onsubmit="return confirm('Decline this request?');">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@r.BookingId" />
                                                <button type="submit" class="mini-btn danger" style="width:100%;">Decline</button>
                                            </form>
                                            <span class="disabled-btn" title="Proposing a new time isn't built yet">Propose new time</span>
                                        </div>
                                    </div>
                                }
                            }
                        </div>

                        <div class="panel">
                            <div class="panel-head"><h2>Recent sessions</h2></div>
                            @if (!Model.RecentSessions.Any())
                            {
                                <p class="empty-state">No past sessions yet.</p>
                            }
                            else
                            {
                                <table class="dash-table">
                                    <thead>
                                        <tr><th>Student</th><th>Date</th><th>Duration</th><th>Status</th></tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var s in Model.RecentSessions)
                                        {
                                            var duration = s.EndTime - s.StartTime;
                                            var statusClass = s.Status == "Completed" ? "completed" : "missed";
                                            <tr>
                                                <td>@s.StudentName</td>
                                                <td>@s.StartTime.ToString("d MMM yyyy")</td>
                                                <td>@($"{(int)duration.TotalHours}h {duration.Minutes:D2}m")</td>
                                                <td><span class="status-text @statusClass">@s.Status</span></td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }
                        </div>
                    </div>

                    <div>
                        <div class="panel">
                            <div class="panel-head">
                                <h2>My students</h2>
                            </div>

                            @if (!Model.MyStudents.Any())
                            {
                                <p class="empty-state">No students yet.</p>
                            }
                            else
                            {
                                @foreach (var s in Model.MyStudents)
                                {
                                    <div class="student-row">
                                        <div class="avatar">@s.Initials</div>
                                        <div class="student-info">
                                            <div class="name">@s.FullName</div>
                                            <div class="meta">@(string.IsNullOrWhiteSpace(s.GradeLevel) ? "" : s.GradeLevel + " · ")@s.SessionsCount session@(s.SessionsCount == 1 ? "" : "s")</div>
                                            <div class="next">Next: @(s.NextSessionAt.HasValue ? s.NextSessionAt.Value.ToString("d MMM, h:mm tt") : "Not scheduled")</div>
                                        </div>
                                        <span class="disabled-btn" title="Tutor-side messaging isn't built yet">Message</span>
                                    </div>
                                }
                            }
                        </div>

                        <div class="panel">
                            <div class="panel-head">
                                <h2>Recent reviews</h2>
                            </div>
                            @if (!Model.RecentReviews.Any())
                            {
                                <p class="empty-state">No reviews yet - they'll show up here once students start leaving them.</p>
                            }
                            else
                            {
                                @foreach (var r in Model.RecentReviews)
                                {
                                    <div class="review-card" style="margin-bottom:1rem;">
                                        <div class="avatar">@r.StudentInitials</div>
                                        <div class="review-body">
                                            <div class="review-top">
                                                <span class="name">@r.StudentName</span>
                                                <span class="when">@r.CreatedAt.ToString("d MMM yyyy")</span>
                                            </div>
                                            <div class="review-stars">@(new string('★', r.Rating))@(new string('☆', 5 - r.Rating))</div>
                                            @if (!string.IsNullOrWhiteSpace(r.Comment))
                                            {
                                                <p class="review-text">"@r.Comment"</p>
                                            }
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </div>
            </main>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>